{
  "name": "ct-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "lint:strict": "eslint src --ext ts,tsx --max-warnings 0",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "verify": "npm run typecheck && npm run lint && npm run test:ci",
    "predeploy": "npm run typecheck && npm run test:ci",
    "gen:api": "cd ../ct-backend && DEBUG=false poetry run python scripts/dump_openapi.py /tmp/ct-openapi.json && cd ../ct-frontend && openapi-typescript /tmp/ct-openapi.json -o src/types/api.generated.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.40.0",
    "@types/js-cookie": "^3.0.6",
    "axios": "^1.7.2",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.541.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
